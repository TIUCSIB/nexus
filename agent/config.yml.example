# Nexus Agent Configuration
#
# Agent uses node_id + global server_token to authenticate with the panel.
# No registration step needed.

panel:
  # Panel HTTP address (the Nexus panel's public/internal address)
  url: "http://localhost:9090"
  # Global server_token from panel settings (System Settings -> server_token)
  token: "your-server-token-here"

# Multiple nodes can be managed by a single agent instance.
# Each node runs its own sing-box process with independent config and stats.
nodes:
  - node_id: 1
    address: "0.0.0.0"
    singbox:
      binary_path: "sing-box"
      config_path: "singbox-1.json"
      working_dir: "."
      stats_port: 9091

  - node_id: 2
    address: "0.0.0.0"
    singbox:
      binary_path: "sing-box"
      config_path: "singbox-2.json"
      working_dir: "."
      stats_port: 9092
